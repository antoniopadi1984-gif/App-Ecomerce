{
    "manifest_version": 3,
    "name": "EcomBoom Spy",
    "version": "1.0",
    "permissions": [
        "activeTab",
        "storage",
        "scripting",
        "downloads"
    ],
    "host_permissions": [
        "https://www.facebook.com/*",
        "https://library.tiktok.com/*",
        "https://*/*"
    ],
    "action": {
        "default_popup": "popup/popup.html"
    },
    "background": {
        "service_worker": "background/service-worker.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.facebook.com/ads/library/*"
            ],
            "js": [
                "content/meta-extractor.js"
            ]
        },
        {
            "matches": [
                "https://library.tiktok.com/*"
            ],
            "js": [
                "content/tiktok-extractor.js"
            ]
        }
    ]
}