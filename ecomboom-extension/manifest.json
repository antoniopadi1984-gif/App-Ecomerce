{
    "manifest_version": 3,
    "name": "EcomBoom Intelligence",
    "version": "1.0",
    "description": "Capture, analyze and replicate competitor creatives with one click.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "downloads",
        "contextMenus",
        "notifications",
        "identity",
        "offscreen",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background/service-worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.facebook.com/ads/library/*"
            ],
            "js": [
                "content-scripts/meta-library.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://www.tiktok.com/*"
            ],
            "js": [
                "content-scripts/tiktok-scraper.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://www.youtube.com/*"
            ],
            "js": [
                "content-scripts/youtube-scraper.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content-scripts/universal-scraper.js",
                "content-scripts/landing-cloner.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "icons/*.png"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}