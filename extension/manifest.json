{
    "manifest_version": 3,
    "name": "EcomFlow Elite Spy",
    "version": "1.2",
    "description": "Capture competitor ads, videos and images directly to your EcomFlow Library.",
    "permissions": [
        "activeTab",
        "storage",
        "contextMenus",
        "notifications",
        "scripting"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "host_permissions": [
        "http://localhost:3000/*",
        "https://*/*"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}