{
    "manifest_version": 3,
    "name": "EcomFlow Control Bridge",
    "version": "2.0",
    "description": "Integration bridge between EcomFlow Control and AI tools (Claude) + Ad Spy.",
    "permissions": [
        "activeTab",
        "storage",
        "notifications",
        "scripting",
        "clipboardRead"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.facebook.com/ads/library*",
                "https://www.tiktok.com/*",
                "https://claude.ai/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "host_permissions": [
        "http://localhost:3000/*",
        "https://claude.ai/*",
        "https://www.facebook.com/*",
        "https://www.tiktok.com/*"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}