// Research Snapshot Model for Auto-save & Version History
model ResearchSnapshot {
  id            String   @id @default(cuid())
  productId     String
  version       Int
  timestamp     DateTime @default(now())
  
  // Snapshot data (JSON)
  productDNA    String   // JSON: Product forensic analysis
  vocInsights   String   // JSON: VOC insights extracted
  avatars       String   // JSON: Avatar analysis
  angles        String   // JSON: Angle strategies
  
  // Meta
  completeness  Float    @default(0)  // 0-100%
  quality       Int      @default(0)  // 1-10
  
  product       Product  @relation(fields: [productId], references: [id])
  
  createdAt     DateTime @default(now())
  
  @@index([productId])
  @@index([version])
  @@unique([productId, version])
}
