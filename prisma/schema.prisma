  // PENDING → PROCESSING → TRANSCRIBED → ANALYZED → ORGANIZED → DONE
  avatarId         String?
  angleId          String?

  // Meta Content & Status
  metaStatus   String? @default("DRAFT") // ACTIVO | PAUSADO | FATIGADO | DRAFT
  thumbnailUrl String?

  // Auto-Tagging & Semantic (Gemini)
  tagsJson            String? // JSON con { tipo_hook, angulo, formato, framework, emocion_dominante }
  semanticDescription String? // Indexación semántica Gemini
  format              String? // UGC | TALKING_HEAD | DEMO | BROLL | etc
  framework           String? // PAS | AIDA | STORY_SELL | etc
  dominantEmotion     String? // URGENGIA | CONFIANZA | EMPATIA | etc

  // Fatigue Detection
  fatigueScore    Float?
  fatigueDaysLeft Int?
  ctrTrend        String? // UP | STABLE | DOWN
  frequency       Float?

  // Versioning & Traceability
  versionGroup   String? // ID para agrupar versiones (V1, V2...)
  sourceAssetId  String? // De dónde viene este asset (traceability)
  similarityHash String? // Hash para detección de similaridad
  isMaster       Boolean @default(true)

