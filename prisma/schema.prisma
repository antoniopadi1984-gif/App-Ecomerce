model DriveAsset {
  id          String   @id @default(cuid())
  productId   String
  driveFileId String   @unique
  drivePath   String
  assetType   String
  sourceUrl   String?
  category    String?
  subcategory String?
  concept     Int?
  organized   Boolean  @default(false)
  createdAt   DateTime @default(now())
  createdBy   String?
  product     Product  @relation(fields: [productId], references: [id])

  @@index([productId, assetType])
  @@index([productId, organized])
  @@index([productId, concept])
}

model ResearchProject {
  id              String            @id @default(cuid())
  productId       String            @unique
  brandName       String
  productName     String
  status          String            @default("PENDING")
  latestVersionId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt
  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  versions        ResearchVersion[]

  @@index([productId])
}

model ResearchVersion {
  id               String            @id @default(cuid())
  projectId        String
  versionNumber    Int
  summaryOfChanges String?
  createdAt        DateTime          @default(now())
  adCopies         AdCopy[]
  creativeProjects CreativeProject[]
  outputs          ResearchOutput?
  project          ResearchProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, versionNumber])
  @@index([projectId])
}

model ResearchOutput {
  id                       String          @id @default(cuid())
  versionId                String          @unique
  macroAvatarSheet         String?
  languageBank             String?
  productIntelligence      String?
  competitorBreakdown      String?
  creativeInsights         String?
  economicsJson            String?
  marketSophisticationJson String?
  competitorIntelJson      String?
  hookAngleDb              String?
  validationReport         String?
  exportsMarkdown          String?
  exportsJson              String?
  createdAt                DateTime        @default(now())
  version                  ResearchVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
}

model SourceDocument {
  id              String   @id @default(cuid())
  projectId       String
  type            String
  url             String
  title           String?
  rawText         String?
  retrievedAt     DateTime
  credibilityTier String?
  createdAt       DateTime @default(now())

  @@index([projectId])
}

model TeamMember {
  id        String   @id @default(cuid())
  storeId   String
  email     String
  role      String
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model AdCopy {
  id                String           @id @default(cuid())
  productId         String
  researchVersionId String?
  avatarId          String?
  angle             String?
  framework         String?
  type              String
  content           String
  status            String           @default("DRAFT")
  createdAt         DateTime         @default(now())
  researchVersion   ResearchVersion? @relation(fields: [researchVersionId], references: [id])
  product           Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AiLearning {
  id          String   @id @default(cuid())
  storeId     String
  insights    String
  winnerCount Int      @default(0)
  loserCount  Int      @default(0)
  date        DateTime @default(now())
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model VideoAsset {
  id           String        @id @default(cuid())
  productId    String
  fileName     String
  driveFileId  String
  duration     Float?
  resolution   String?
  fps          Float?
  originalSize Int?
  cleanSize    Int?
  hasMetadata  Boolean       @default(true)
  status       String        @default("UPLOADED")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  clips        VideoClip[]
  scripts      VideoScript[]

  @@index([productId])
  @@index([status])
}

model VideoScript {
  id             String      @id @default(cuid())
  productId      String
  videoAssetId   String?
  transcript     String
  timestampsJson String?
  language       String      @default("es")
  driveFileId    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  videoAsset     VideoAsset? @relation(fields: [videoAssetId], references: [id], onDelete: Cascade)
  product        Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([videoAssetId])
}

model Avatar {
  id               String     @id @default(cuid())
  productId        String?
  name             String
  type             String
  gender           String?
  age              Int?
  ethnicity        String?
  styleJson        String?
  voiceId          String?
  language         String     @default("es")
  tone             String?
  avatarImageUrl   String?
  avatarModelUrl   String?
  researchDataJson String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  product          Product?   @relation(fields: [productId], references: [id])
  creatives        Creative[]

  @@index([productId])
  @@index([type])
}

model Creative {
  id               String   @id @default(cuid())
  productId        String
  type             String
  subtype          String?
  title            String?
  scriptText       String?
  scriptFramework  String?
  assetUrl         String?
  thumbnailUrl     String?
  duration         Int?
  dimensions       String?
  format           String?
  avatarId         String?
  funnelStage      String?
  targetAudience   String?
  status           String   @default("DRAFT")
  performanceScore Float?
  driveFolderId    String?
  driveFileId      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  avatar           Avatar?  @relation(fields: [avatarId], references: [id])
  product          Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([funnelStage])
  @@index([status])
  @@index([type])
}

model CreativeTemplate {
  id               String   @id @default(cuid())
  name             String
  category         String
  funnelStage      String?
  templateJson     String
  previewUrl       String?
  requiredFields   String?
  supportedFormats String?
  usageCount       Int      @default(0)
  createdAt        DateTime @default(now())

  @@index([category])
  @@index([funnelStage])
}

model ScriptLibrary {
  id             String   @id @default(cuid())
  productId      String?
  framework      String
  funnelStage    String
  hook           String
  body           String
  cta            String
  duration       Int?
  wordCount      Int?
  conversionRate Float?
  usageCount     Int      @default(0)
  avgCTR         Float?
  avgCPC         Float?
  createdAt      DateTime @default(now())
  product        Product? @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([framework])
  @@index([funnelStage])
}

model GeneratedCreative {
  id             String   @id @default(cuid())
  productId      String?
  storeId        String?
  type           String
  stage          String?
  avatarUrl      String?
  audioUrl       String?
  videoUrl       String
  thumbnailUrl   String?
  captionsUrl    String?
  concept        String
  script         String?
  prompt         String?
  generatedBy    String   @default("creative-factory")
  generationCost Float    @default(0)
  views          Int      @default(0)
  clicks         Int      @default(0)
  ctr            Float?
  conversions    Int      @default(0)
  spend          Float    @default(0)
  revenue        Float    @default(0)
  qualityScore   Float?
  userRating     Int?
  status         String   @default("GENERATED")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  store          Store?   @relation(fields: [storeId], references: [id])
  product        Product? @relation(fields: [productId], references: [id])
}

model AgentPromptLibrary {
  id              String   @id @default(cuid())
  agentType       String
  category        String
  name            String
  prompt          String
  description     String?
  successRate     Float    @default(0.5)
  timesUsed       Int      @default(0)
  avgQualityScore Float?
  avgCTR          Float?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AgentLearning {
  id              String   @id @default(cuid())
  agentType       String
  taskType        String
  creativeId      String?
  inputData       String
  outputData      String
  promptUsed      String
  userFeedback    String?
  qualityScore    Float?
  performanceData String?
  createdAt       DateTime @default(now())
}

model CompetitiveAnalysis {
  id             String   @id @default(cuid())
  productId      String
  competitorName String
  competitorUrl  String?
  price          Float?
  rating         Float?
  reviewCount    Int?
  strengths      String
  weaknesses     String
  gapOpportunity String?
  createdAt      DateTime @default(now())
  product        Product  @relation(fields: [productId], references: [id])

  @@index([productId])
}

model OfferStack {
  id         String   @id @default(cuid())
  productId  String
  name       String
  strategy   String
  components String
  totalValue Float
  price      Float
  discount   Float
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id])

  @@index([productId])
}

model VOCInsight {
  id                 String   @id @default(cuid())
  productId          String
  researchRunId      String?
  phrase             String
  category           String
  emotionalIntensity Int
  funnelStage        String?
  frequency          Int      @default(1)
  verbatimSource     String?
  createdAt          DateTime @default(now())
  product            Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([category])
}
