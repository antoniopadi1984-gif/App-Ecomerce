  @@unique([userId, module])
  @@map("user_preferences")
}

model Task {
  id          String    @id @default(cuid())
  storeId     String
  title       String
  description String?
  assignedTo  String?
  status      String    @default("TODO")
  priority    String    @default("MEDIUM")
  dueDate     DateTime?
  completedAt DateTime?
  orderId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  store       Store     @relation(fields: [storeId], references: [id])

  @@index([storeId, status])
  @@index([assignedTo])
}

enum CreativeType {
  VIDEO
  STATIC
  SCRIPT
  HOOK
  LANDING
  AVATAR
}

enum FunnelStage {
  COLD
  WARM
  HOT
  RETARGETING
}

enum MetaAdStatus {
  NOT_PUBLISHED
  ACTIVE
  PAUSED
  FATIGUED
}

enum RelationType {
  DERIVED_FROM
  VERSION_OF
  CLONE_OF
  USED_IN
}

