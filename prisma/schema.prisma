  @@index([productId])
}

// ─── DriveFile — índice de archivos de Google Drive ───────────────
model DriveFile {
  id           String    @id @default(cuid())
  storeId      String
  productId    String?
  driveFileId  String    @unique
  drivePath    String
  fileName     String
  conceptCode  String?
  funnelStage  String?
  fileType     String
  nomenclature String?
  sizeBytes    Int?
  mimeType     String?
  thumbnailUrl String?
  processedAt  DateTime?
  createdAt    DateTime  @default(now())
  syncedAt     DateTime  @default(now())
  store        Store     @relation(fields: [storeId], references: [id])
  product      Product?  @relation(fields: [productId], references: [id])

  @@index([storeId])
  @@index([productId])
  @@index([conceptCode])
}

model DriveFolder {
  id            String   @id @default(cuid())
  storeId       String
  productId     String
  path          String
  driveFolderId String   @unique
  createdAt     DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, path])
}

model CompetitorBrand {
  id             String    @id @default(cuid())
  storeId        String
  productId      String?
  name           String
  websiteUrl     String?
  trackingActive Boolean   @default(true)
  lastTracked    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  store    Store               @relation(fields: [storeId], references: [id])
  product  Product?            @relation(fields: [productId], references: [id])
  ads      CompetitorAd[]
  landings CompetitorLanding[]

  @@index([storeId])
}

model CompetitorAd {
  id           String  @id @default(cuid())
  brandId      String?
  storeId      String
  productId    String?
  title        String?
  url          String?
  videoUrl     String?
  thumbnailUrl String?
  platform     String? // META | TIKTOK | YOUTUBE
  status       String? // ACTIVE | INACTIVE
  source       String? // MANUAL | AUTO_TRACKING

  // AI Analysis (Gemini 3.1 Pro)
  analysisJson   String? // Full breakdown: timeline, transcription, why it works, etc.
  blueprintJson  String? // Structure for Viral Clone Mode
  diagnostic     String?
  framework      String?
  avatarTarget   String?
  sellingAngle   String?
  offerType      String?
  awarenessLevel String?

  firstSeen DateTime  @default(now())
  lastSeen  DateTime?
  createdAt DateTime  @default(now())

  brand   CompetitorBrand? @relation(fields: [brandId], references: [id])
  store   Store            @relation(fields: [storeId], references: [id])
  product Product?         @relation(fields: [productId], references: [id])

  @@index([storeId])
}

model CompetitorLanding {
  id            String  @id @default(cuid())
  brandId       String?
  storeId       String
  productId     String?
  name          String?
  url           String
  screenshotUrl String?
  localPath     String? // Path to downloaded HTML/CSS

  // AI Analysis
  type            String? // ADVERTORIAL | DIRECT | LISTICLE | VSL
  offerAnalysis   String?
  visualHierarchy String?
  copyAnalysis    String?
  targetTraffic   String?
  diagnostic      String?
  conversionScore Int?
  analysisJson    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand           CompetitorBrand? @relation(fields: [brandId], references: [id])
  store           Store            @relation(fields: [storeId], references: [id])
  product         Product?         @relation(fields: [productId], references: [id])
  extractedAssets ExtractedAsset[]

  @@index([storeId])
}

model ExtractedAsset {
  id        String   @id @default(cuid())
  landingId String
  type      String // IMAGE | TEXT
  category  String? // PRODUCT | LIFESTYLE | ICON | UGC | BEFORE_AFTER | BADGE
  content   String? // Text content or URL
  url       String?
  drivePath String?
  createdAt DateTime @default(now())

  landing CompetitorLanding @relation(fields: [landingId], references: [id], onDelete: Cascade)
}

model InspirationAsset {
  id             String  @id @default(cuid())
  storeId        String
  productId      String?
  type           String // VIDEO | IMAGE
  sourceUrl      String?
  thumbnailUrl   String?
  driveUrl       String?
  sourcePlatform String? // TIKTOK | INSTAGRAM | YOUTUBE | etc

  // AI Tagging
  label        String?
  sector       String? // e.g. Fitness, Tech, Home
  emotion      String? // e.g. Surprise, Happiness, Skepticism
  hookType     String? // e.g. Question, Visual Pattern, Direct Pain
  semanticDesc String?
  analysisJson String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store   Store    @relation(fields: [storeId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([storeId])
}

// --- CREATIVE CENTER MODELS ---

enum CreativeType {
  VIDEO
  STATIC
  SCRIPT
  HOOK
  LANDING
  AVATAR
}

enum FunnelStage {
  COLD
  WARM
  HOT
  RETARGETING
}

enum MetaAdStatus {
  NOT_PUBLISHED
  ACTIVE
  PAUSED
  FATIGUED
}

enum RelationType {
  DERIVED_FROM
  VERSION_OF
  CLONE_OF
  USED_IN
}

model CreativeArtifact {
  id        String  @id @default(cuid())
  storeId   String
  productId String
  conceptId String
  avatarId  String?
  angleId   String?
  scriptId  String?
  landingId String?
  offerId   String?

  // Nomenclatura
  creativeCode  String  @unique // "PURE-MECH01-C-V1"
  version       Int
  variantSuffix String? // "a", "b", "c" for variants

  // Tipo y formato
  type            CreativeType
  format          String // "9:16" | "4:5" | "1:1"
  durationSeconds Int?
  funnelStage     FunnelStage
  framework       String // PAS | AIDA | etc.
  hookType        String // curiosidad | miedo | etc.
  emotion         String

  // Archivos
  driveUrl     String
  driveFileId  String
  thumbnailUrl String

  // Estado en Meta
  metaAdId   String?
  metaStatus MetaAdStatus

  // Scores
  preLaunchScore Float?

  // Metadatos de generación
  modelsUsed     String? // Replicando patrón de String para JSON
  promptsUsed    String? // Replicando patrón de String para JSON
  generationCost Float // coste estimado en USD de las APIs usadas
  metricsJson    String? // Metadatos de rendimiento de Meta Ads

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  store     Store                @relation(fields: [storeId], references: [id])
  product   Product              @relation(fields: [productId], references: [id])
  metrics   CreativeMetaMetric[]
  edgesFrom ArtifactEdge[]       @relation("FromArtifact")
  edgesTo   ArtifactEdge[]       @relation("ToArtifact")

  @@index([storeId])
  @@index([productId])
}

model CreativeMetaMetric {
  id         String   @id @default(cuid())
  creativeId String
  date       DateTime

  // Alcance y entrega
  impressions Int
  reach       Int
  frequency   Float

  // Engagement video
  videoThruplayWatched Int
  videoP25Watched      Int
  videoP50Watched      Int
  videoP75Watched      Int
  video2sContinuous    Int
  hookRate             Float // video_2s / impressions * 100
  watch25Rate          Float
  watch50Rate          Float

  // Clicks
  clicks     Int
  linkClicks Int
  ctr        Float
  cpc        Float
  cpm        Float

  // Conversiones
  conversions     Int
  conversionValue Float
  cvr             Float

  // Coste
  spend Float
  cpa   Float
  roas  Float

  // Datos de retención
  retentionCurve String? // Replicando patrón de String para JSON

  creative CreativeArtifact @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  @@index([creativeId])
  @@index([date])
}

model SavedHook {
  id           String      @id @default(cuid())
  storeId      String
  productId    String
  conceptId    String
  text         String
  type         String // curiosidad | miedo | etc.
  funnelStage  FunnelStage
  metaHookRate Float? // si se ha publicado y tiene datos
  isWinner     Boolean     @default(false)
  createdAt    DateTime    @default(now())

  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([storeId])
  @@index([productId])
}

model AiAvatar {
  id         String @id @default(cuid())
  avatarCode String @unique // "PURE-AV01"
  storeId    String
  productId  String
  name       String

  // Voz ElevenLabs
  elevenVoiceId   String
  voiceStability  Float
  voiceSimilarity Float
  voiceStyle      Float

  // Assets del pack
  photoFrontalUrl   String
  photo34Url        String
  photoLifestyleUrl String
  clipGreetingUrl   String
  clipPointingUrl   String
  clipsExpressions  String? // Replicando patrón de String para JSON

  createdAt DateTime @default(now())

  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([storeId])
  @@index([productId])
}

model ArtifactEdge {
  id             String       @id @default(cuid())
  fromArtifactId String
  toArtifactId   String
  relation       RelationType
  metadata       String? // Replicando patrón de String para JSON
  createdAt      DateTime     @default(now())

  fromArtifact CreativeArtifact @relation("FromArtifact", fields: [fromArtifactId], references: [id])
  toArtifact   CreativeArtifact @relation("ToArtifact", fields: [toArtifactId], references: [id])

  @@index([fromArtifactId])
  @@index([toArtifactId])
}

model CompetitorTracking {
  id             String    @id @default(cuid())
  storeId        String
  productId      String
  brandName      String
  metaPageId     String?
  trackingActive Boolean
  lastCheckedAt  DateTime?
  createdAt      DateTime  @default(now())

  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([storeId])
  @@index([productId])
}

model CompetitorVideo {
  id              String   @id @default(cuid())
  productId       String
  storeId         String
  sourceUrl       String?
  filename        String
  thumbnailUrl    String?
  previewUrl      String?
  status          String   @default("ANALIZANDO") // ANALIZANDO | LISTO | ERROR
  hookDetected    String?
  hookType        String?
  framework       String?
  fase            String?
  formato         String?
  duracion        String?
  idiomaDetectado String?
  idiomaDestino   String?
  analysisJson    String? // El análisis completo (transcripción, visual, psicológico)
  voiceoverScript     String? // Transcripción del voiceover (Step 1)
  tomasCount          Int      @default(0) // Cantidad de tomas extraídas (Step 2)
  vocalsUrl           String? // URL del audio solo voces
  musicUrl            String? // URL del audio solo música/fondo
  noVocalsUrl         String? // URL del vídeo final sin voces
  googleDriveTomasId  String? // ID de la carpeta de tomas en Drive
  voiceoverRemoved    Boolean  @default(false)
  libraryId           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  product Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  library CompetitorLibrary? @relation(fields: [libraryId], references: [id])

  @@index([productId])
  @@index([storeId])
}

model CompetitorLibrary {
  id             String    @id @default(cuid())
  storeId        String
  productId      String?
  advertiserId   String? // ID de Meta Advertiser
  advertiserUrl  String
  advertiserName String?
  status         String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  adCount        Int       @default(0)
  platform       String    @default("META")
  lastSyncAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  store            Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product          Product?          @relation(fields: [productId], references: [id], onDelete: Cascade)
  competitorVideos CompetitorVideo[]

  @@index([storeId])
  @@index([productId])
  @@map("competitor_libraries")
}

model LandingClone {
  id            String   @id @default(cuid())
  storeId       String
  productId     String?
  originalUrl   String
  clonedUrl     String? // URL de la versión clonada alojada
  status        String   @default("PENDING") // PENDING, CLONING, COMPLETED, FAILED
  assetsJson    String? // JSON con mapeo de assets (original -> local)
  screenshotUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store   Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([productId])
  @@map("landing_clones")
}

model ExtensionCapture {
  id        String   @id @default(cuid())
  storeId   String
  productId String?
  userId    String?
  url       String
  assetType String // IMAGE, VIDEO, GIF, LANDING, AD
  assetUrl   String
  cleanedUrl String?
  audioJson  String? // JSON con URLs de voz/música
  localPath  String?
  metadata   String? // JSON con dimensiones, duración, etc.
  status     String  @default("SAVED")
  createdAt DateTime @default(now())

  store   Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id])
  job     MediaJob?

  @@index([storeId])
  @@index([productId])
  @@index([userId])
  @@map("extension_captures")
}

model MediaJob {
  id          String   @id @default(cuid())
  captureId   String   @unique
  status      String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  currentStep Int      @default(0)
  totalSteps  Int      @default(0)
  stepsLog    String?  // JSON con { step: string, status: string, timestamp: string }
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  capture ExtensionCapture @relation(fields: [captureId], references: [id], onDelete: Cascade)

  @@map("media_jobs")
}

// --- AGENT CONFIGS ---

enum AgentId {
  FINANZAS
  CRM
  CREATIVO
  INVESTIGACION
  MARKETING
  MANDO
  OPERACIONES
  DIRECTOR
  ESPECIALISTA_CREATIVO
  DIRECTOR_MARKETING
  AGENTE_OPERACIONES
}

model AgentConfig {
  id           String   @id @default(cuid())
  storeId      String   @map("store_id")
  agentId      AgentId  @map("agent_id")
  systemPrompt String   @map("system_prompt")
  examples     Json?    @map("examples")
  updatedAt    DateTime @updatedAt @map("updated_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, agentId])
  @@map("agent_configs")
}

model MetaInsightsCache {
  id            String   @id @default(cuid())
  storeId       String
  accountId     String
  level         String   // CAMPAIGN | ADSET | AD
  externalId    String   // ID de Meta
  name          String
  status        String
  spend         Float    @default(0)
  impressions   Int      @default(0)
  reach         Int      @default(0)
  frequency     Float    @default(0)
  clicks        Int      @default(0)
  cpc           Float    @default(0)
  ctr           Float    @default(0)
  cpm           Float    @default(0)
  results       Int      @default(0)
  costPerResult Float    @default(0)
  roas          Float    @default(0)
  hookRate      Float    @default(0)
  holdRate      Float    @default(0)
  budget        Float?
  objective     String?
  bidStrategy   String?
  deliveryVerdict String?
  date          DateTime
  metadata      String?  // JSON stringified
  updatedAt     DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, accountId, level, date])
  @@map("meta_insights_cache")
}

model UserPreference {
  id        String   @id @default(cuid())
  userId    String
  module    String   // e.g., 'ads'
  config    String   // JSON stringified: { columnOrder: [], hiddenColumns: [], ... }
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@map("user_preferences")
}

model Task {
  id          String    @id @default(cuid())
  storeId     String
  title       String
  description String?
  assignedTo  String?   // userId del gestor
  status      String    @default("TODO") // TODO | IN_PROGRESS | DONE | BLOCKED
  priority    String    @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  dueDate     DateTime?
  completedAt DateTime?
  orderId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  store       Store     @relation(fields: [storeId], references: [id])
 
  @@index([storeId, status])
  @@index([assignedTo])
}

