}

model CreativeArtifact {
  id              String               @id @default(cuid())
  storeId         String
  productId       String
  conceptId       String
  avatarId        String?
  angleId         String?
  scriptId        String?
  landingId       String?
  offerId         String?
  creativeCode    String               @unique
  version         Int
  variantSuffix   String?
  type            CreativeType
  format          String
  durationSeconds Int?
  funnelStage     FunnelStage
  framework       String
  hookType        String
  emotion         String
  driveUrl        String
  driveFileId     String
  thumbnailUrl    String
  metaAdId        String?
  metaStatus      MetaAdStatus
  preLaunchScore  Float?
  modelsUsed      String?
  promptsUsed     String?
  generationCost  Float
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  publishedAt     DateTime?
  metricsJson     String?
  edgesTo         ArtifactEdge[]       @relation("ToArtifact")
  edgesFrom       ArtifactEdge[]       @relation("FromArtifact")
  product         Product              @relation(fields: [productId], references: [id])
  store           Store                @relation(fields: [storeId], references: [id])
  metrics         CreativeMetaMetric[]

  @@index([storeId])
  @@index([productId])
}

model CreativeMetaMetric {
