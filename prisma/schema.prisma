model ArtifactEdge {
  id             String           @id @default(cuid())
  fromArtifactId String
  toArtifactId   String
  relation       RelationType
  metadata       String?
  createdAt      DateTime         @default(now())
  toArtifact     CreativeArtifact @relation("ToArtifact", fields: [toArtifactId], references: [id])
  fromArtifact   CreativeArtifact @relation("FromArtifact", fields: [fromArtifactId], references: [id])

  @@index([fromArtifactId])
  @@index([toArtifactId])
}

model CompetitorTracking {
  id             String    @id @default(cuid())
  storeId        String
  productId      String
  brandName      String
  metaPageId     String?
  trackingActive Boolean
  lastCheckedAt  DateTime?
  createdAt      DateTime  @default(now())
  product        Product   @relation(fields: [productId], references: [id])
  store          Store     @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([productId])
}

model CompetitorVideo {
