generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String?
  password          String?
  // Usuario extended fields
  nombre            String? // nombre propio  (migración añadida)
  apellido          String? // apellido
  rol               String             @default("visor") // admin | gestor | agente_ia | visor
  tipo              String             @default("humano") // humano | bot
  estado            String             @default("activo") // activo | invitado | inactivo
  avatar            String? // URL foto o avatar
  color             String             @default("#64748b") // color identificativo en la UI
  invitadoPor       String? // id del usuario que lo invitó
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  auditLogs         AuditLog[]
  stores            UserStoreAccess[]
  workSessions      WorkSession[]
  connections       UserConnection[]
  extensionCaptures ExtensionCapture[]
  activeProductId   String?
  preferences       UserPreference[]
}

model UserConnection {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  secretEnc String?
  secretIv  String?
  secretTag String?
  isActive  Boolean  @default(true)
  metadata  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model UserStoreAccess {
  id      String @id @default(cuid())
  userId  String
  storeId String
  role    String @default("ATT")
  store   Store  @relation(fields: [storeId], references: [id])
  user    User   @relation(fields: [userId], references: [id])

  @@unique([userId, storeId])
}

model Store {
  id                   String                  @id @default(cuid())
  name                 String
  domain               String?
  currency             String                  @default("EUR")
  brandKit             String?
  swipeFile            String?
  safeModeAds          Boolean                 @default(true)
  aggressiveLandings   Boolean                 @default(true)
  nomenclatureTemplate String                  @default("[PROD]_[CONC]_[VAR]_[LANG]")
  targetProfitMargin   Float                   @default(30.0)
  adSpendSource        String                  @default("MANUAL")
  driveRootFolderId    String?
  adMetrics            AdMetricDaily[]
  agentActions         AgentAction[]
  agentCorrections     AgentCorrection[]
  agentProfiles        AgentProfile[]
  agentRuns            AgentRun[]
  aiBudgets            AiBudget[]
  aiLearnings          AiLearning[]
  aiUsageLogs          AiUsageLog[]
  auditLogs            AuditLog[]
  avatarProfiles       AvatarProfile[]
  research             AvatarResearch[]
  // Legacy Clowdbot configuration (Keep for backward compatibility, do not create new references)
  clowdbotConfig       ClowdbotConfig?
  connections          Connection[]
  contentAssets        ContentAsset[]
  contentCampaigns     ContentCampaign[]
  deliveryLogs         ContentDeliveryLog[]
  contentTemplates     ContentTemplate[]
  conversations        Conversation[]
  creativeAssets       CreativeAsset[]
  creativeBlueprints   CreativeBlueprint[]
  customers            Customer[]
  competitorBrands     CompetitorBrand[]
  competitorAds        CompetitorAd[]
  competitorLandings   CompetitorLanding[]
  finances             DailyFinance[]
  snapshots            DailySnapshot[]
  expenses             Expense[]
  agentConfigs         AgentConfig[]
  fulfillmentRules     FulfillmentRule[]
  generatedCreatives   GeneratedCreative[]
  inspirationAssets    InspirationAsset[]
  historicalSheets     HistoricalSpreadsheet[]
  scenarios            HypothesisScenario[]
  landingProjects      LandingProject[]
  landingSections      LandingSection[]
  languageDictionaries LanguageDictionary[]
  ledgerEntries        LedgerEntry[]
  moderationRules      ModerationRule[]
  monthlyGoals         MonthlyGoal[]
  templates            NotificationTemplate[]
  orders               Order[]
  products             Product[]
  themes               ShopifyTheme[]
  socialAccounts       SocialAccount[]
  suppliers            Supplier[]
  teamMembers          TeamMember[]
  thresholds           ThresholdConfig[]
  users                UserStoreAccess[]
  whatsappAccounts     WhatsAppAccount[]
  alertRules           AlertRule[]
  creativeBatches      CreativeBatch[]
  metaAdAccounts       MetaAdAccount[]
  creativeArtifacts    CreativeArtifact[]
  savedHooks           SavedHook[]
  aiAvatars            AiAvatar[]
  competitorTrackings  CompetitorTracking[]
  storeType            String                  @default("HYBRID")
  scoreCardConfig      ScoreCardConfig?
  concepts             Concept[]
  performanceRecs      PerformanceRecord[]
  perceivedValues      PerceivedValue[]
  automations          Automation[]
  competitorAnalyses   CompetitorAnalysis[]
  driveFiles           DriveFile[]
  driveSetupDone       Boolean                 @default(false)
  tasks                Task[]
  finanzasConfig       FinanzasConfig?
  competitorVideos     CompetitorVideo[]
  competitorLibraries  CompetitorLibrary[]
  landingClones        LandingClone[]
  extensionCaptures    ExtensionCapture[]
  metaInsights         MetaInsightsCache[]
  automationRules      AutomationRule[]
}

model AutomationRule {
  id        String   @id @default(cuid())
  storeId   String
  ruleId    String
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id])
 
  @@unique([storeId, ruleId])
}

model FinanzasConfig {
  id             String   @id @default(cuid())
  storeId        String   @unique
  thresholdsJson String?
  kpiOrderJson   String?
  kpiEnabledJson String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model MetaAdAccount {
  id        String   @id @default(cuid())
  storeId   String
  accountId String
  name      String
  currency  String?
  status    String   @default("ACTIVE")
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, accountId])
}

model AlertRule {
  id        String   @id @default(cuid())
  storeId   String
  scope     String // ORDERS | PRODUCTS | FINANCES | MARKETING
  field     String // cpa, roas, cost, etc.
  operator  String // GT, GTE, LT, LTE, EQ
  threshold Float
  label     String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model HistoricalSpreadsheet {
  id            String    @id @default(cuid())
  storeId       String
  name          String
  spreadsheetId String
  range         String    @default("Sheet1!A1:Z")
  status        String    @default("ACTIVE")
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  store         Store     @relation(fields: [storeId], references: [id])
}

model ShopifyTheme {
  id             String   @id @default(cuid())
  storeId        String
  name           String
  shopifyThemeId String?  @unique
  role           String   @default("UNSET")
  primaryColor   String?
  secondaryColor String?
  fontFamily     String?
  sectionsJson   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  store          Store    @relation(fields: [storeId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  storeId   String
  userId    String?
  action    String
  entity    String
  entityId  String
  oldValue  String?
  newValue  String?
  actorType String   @default("HUMAN")
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}

model WorkSession {
  id          String    @id @default(cuid())
  userId      String
  startTime   DateTime  @default(now())
  endTime     DateTime?
  duration    Int?
  cost        Float     @default(0)
  activityLog String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
}

model AiBudget {
  id            String   @id @default(cuid())
  storeId       String?
  scope         String   @default("GLOBAL")
  dailyLimitEur Float    @default(50.0)
  currentUsage  Float    @default(0.0)
  mode          String   @default("BALANCED")
  hardStop      Boolean  @default(false)
  lastResetAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  store         Store?   @relation(fields: [storeId], references: [id])
}

model AiUsageLog {
  id               String   @id @default(cuid())
  storeId          String?
  provider         String
  model            String
  taskType         String
  inputTokens      Int?
  outputTokens     Int?
  estimatedCostEur Float    @default(0)
  latencyMs        Int?
  status           String   @default("SUCCESS")
  error            String?
  createdAt        DateTime @default(now())
  store            Store?   @relation(fields: [storeId], references: [id])
}

model Supplier {
  id          String    @id @default(cuid())
  storeId     String
  name        String
  contactName String?
  email       String?
  phone       String?
  rating      Int?      @default(5)
  alias       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  store       Store     @relation(fields: [storeId], references: [id])
}

model Connection {
  id            String    @id @default(cuid())
  storeId       String
  provider      String
  apiKey        String? // @deprecated — Use secretEnc instead
  apiSecret     String? // @deprecated — Use secretEnc instead
  accessToken   String? // @deprecated — Use secretEnc instead
  secretEnc     String? // AES-256-GCM encrypted
  secretIv      String? // Initialization Vector
  secretTag     String? // Auth Tag for GCM
  webhookSecret String?
  webhookUrl    String?
  extraConfig   String?
  isActive      Boolean   @default(true)
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  store         Store     @relation(fields: [storeId], references: [id])

  @@unique([storeId, provider])
}

model Customer {
  id           String    @id @default(cuid())
  storeId      String
  name         String
  email        String?
  phone        String
  addressLine1 String?
  addressLine2 String?
  city         String?
  province     String?
  zip          String?
  country      String?
  totalOrders  Int       @default(0)
  totalSpent   Float     @default(0)
  avgTicket    Float     @default(0)
  tags         String?
  notes        String?
  lastOrderAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  store        Store     @relation(fields: [storeId], references: [id])
  orders       Order[]

  @@unique([storeId, phone])
  @@index([email])
}

model Product {
  id                  String                 @id @default(cuid())
  storeId             String
  shopifyId           String?                @unique
  title               String
  description         String?
  price               Float                  @default(0)
  compareAtPrice      Float?
  imageUrl            String?
  variantId           String?
  sku                 String?
  unitCost            Float?
  inventoryQuantity   Int                    @default(0)
  status              String                 @default("ACTIVE")
  tags                String?
  productType         String?
  vendor              String?
  handle              String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  supplierId          String?
  driveFolders        DriveFolder[]
  handlingCost        Float?                 @default(0)
  returnCost          Float?                 @default(0)
  shippingCost        Float?                 @default(0)
  vatPercent          Float?                 @default(21)
  country             String?                @default("ES")
  landingUrl          String?
  niche               String?
  problemToSolve      String?
  driveFolderId       String?
  driveRootPath       String?
  amazonLinks         String?
  competitorImages    String?
  landingUrls         String?
  productImages       String?
  breakevenCPC        Float?
  breakevenROAS       Float?
  desiredPrice        Float?
  pricingOffers       String?
  targetMargin        Float?                 @default(40)
  productFamily       String?
  driveDocId          String?
  driveDocUrl         String?
  isWinnersOnly       Boolean                @default(false)
  marketLanguage      String                 @default("ES") // idioma del mercado (EN, FR, IT, DE, etc.)
  interfaceLanguage   String                 @default("ES") // idioma de la interfaz (siempre ES)
  currency            String                 @default("EUR")
  pvpEstimated        Float?
  cvrExpected         Float?
  cpaMax              Float?
  adLibraryUrls       String? // JSON array of Facebook Ad Library URLs
  foreplayBoardUrl    String? // Foreplay board URL for spy ads
  googleDocUrl        String? // External research doc
  agentDescription    String? // AI-generated description
  adCopies            AdCopy[]
  avatars             Avatar[]
  avatarProfiles      AvatarProfile[]
  avatarResearches    AvatarResearch[]
  CompetitiveAnalysis CompetitiveAnalysis[]
  competitorLandings  CompetitorLanding[]
  competitorAds       CompetitorAd[]
  competitorBrands    CompetitorBrand[]
  competitorLinks     CompetitorLink[]
  assets              ContentAsset[]
  templates           ContentTemplate[]
  copyArtifacts       CopyArtifact[]
  copyContracts       CopyContract[]
  copyJobs            CopyJob[]
  creatives           Creative[]
  creativeAssets      CreativeAsset[]
  blueprints          CreativeBlueprint[]
  inspirationAssets   InspirationAsset[]
  creativeProjects    CreativeProject[]
  driveAssets         DriveAsset[]
  evidenceChunks      EvidenceChunk[]
  funnelAnalyses      FunnelAnalysis[]
  GeneratedCreative   GeneratedCreative[]
  knowledgeNodes      KnowledgeNode[]
  landingProjects     LandingProject[]
  dictionaries        LanguageDictionary[]
  angles              MarketingAngle[]
  metaConfig          MetaConfig?
  OfferStack          OfferStack[]
  itemOf              OrderItem[]
  pageBlueprints      PageBlueprint[]
  store               Store                  @relation(fields: [storeId], references: [id])
  supplier            Supplier?              @relation(fields: [supplierId], references: [id])
  finance             ProductFinance?
  branding            ProductBranding?
  maturity            ProductMaturity?
  documents           ResearchDocument[]
  researchProjects    ResearchProject?
  researchRuns        ResearchRun[]
  researchSessions    ResearchSession[]
  researchSources     ResearchSource[]
  scriptLibrary       ScriptLibrary[]
  searchQueries       SearchQuery[]
  VOCInsight          VOCInsight[]
  videoAssets         VideoAsset[]
  videoClips          VideoClip[]
  videoJobs           VideoJob[]
  videoScripts        VideoScript[]
  vocQuotes           VoiceOfCustomerQuote[]
  creativeBatches     CreativeBatch[]
  concepts            Concept[]
  combos              ComboMatrix[]
  researchSteps       ResearchStep[]
  competitorAnalyses  CompetitorAnalysis[]
  amazonReviews       AmazonReview[]
  creativeArtifacts   CreativeArtifact[]
  savedHooks          SavedHook[]
  aiAvatars           AiAvatar[]
  competitorTrackings CompetitorTracking[]
  competitorLibraries CompetitorLibrary[]
  landingClones       LandingClone[]
  extensionCaptures   ExtensionCapture[]
  driveFiles          DriveFile[]
  driveSetupDone      Boolean?               @default(false)
  driveIndexPath      String? // ruta del index.json en Drive
  competitorVideos    CompetitorVideo[]
}

model Order {
  id                     String               @id @default(cuid())
  storeId                String
  customerId             String?
  shopifyId              String?              @unique
  orderNumber            String?
  orderType              String               @default("REGULAR")
  abandonedId            String?              @unique
  draftId                String?              @unique
  customerName           String?
  customerEmail          String?
  customerPhone          String?
  customerIp             String?
  userAgent              String?
  addressLine1           String?
  addressLine2           String?
  city                   String?
  province               String?
  zip                    String?
  country                String?
  addressStatus          String               @default("PENDING")
  correctedAddress       String?
  geolocation            String?
  lat                    Float?
  lng                    Float?
  totalPrice             Float                @default(0)
  totalTax               Float                @default(0)
  shippingCost           Float                @default(0)
  paymentMethod          String               @default("COD")
  financialStatus        String?
  currency               String               @default("EUR")
  discounts              Float                @default(0)
  discountCode           String?
  status                 String               @default("PENDING")
  fulfillmentStatus      String?
  carrier                String?
  trackingCode           String?
  shippedAt              DateTime?
  deliveredAt            DateTime?
  returnedAt             DateTime?
  returnReason           String?
  estimatedLogisticsCost Float                @default(0)
  warehouse              String?
  priority               String?
  logisticsProvider      String?
  trackingUrl            String?
  logisticsStatus        String?
  finalStatus            String?
  confirmationDate       DateTime?
  confirmationAttempts   Int                  @default(0)
  incidenceResult        String?
  incidenceReason        String?
  incidenceAttempts      Int                  @default(0)
  needsReview            Boolean              @default(false)
  productTitle           String?
  variantTitle           String?
  sku                    String?
  units                  Int                  @default(1)
  assignedAgentId        String?
  processedAt            DateTime?
  incidenciaType         String?
  notes                  String?
  shopifyNote            String?
  tags                   String?
  whatsappSent           Boolean              @default(false)
  msgConfirmationSent    Boolean              @default(false)
  msgTrackingSent        Boolean              @default(false)
  msgDeliverySent        Boolean              @default(false)
  msgIncidenceSent       Boolean              @default(false)
  callAttempt1           String?
  callAttempt2           String?
  callAttempt3           String?
  callRecordingUrl       String?
  phoneValidated         Boolean              @default(false)
  source                 String?
  medium                 String?
  campaign               String?
  content                String?
  term                   String?
  adsetId                String?
  adId                   String?
  rawJson                String?
  shopifyUpdatedAt       DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  estimatedProfit        Float?
  realProfit             Float?
  fulfillmentCost        Float?               @default(0)
  netProfit              Float?
  netMargin              Float?
  riskScore              Int                  @default(0)
  riskLevel              String               @default("LOW")
  fraudScore             Int                  @default(0)
  fraudStatus            String               @default("PENDING")
  shopifyOrderId         String?              @unique
  deliveryLogs           ContentDeliveryLog[]
  messages               Message[]
  store                  Store                @relation(fields: [storeId], references: [id])
  customer               Customer?            @relation(fields: [customerId], references: [id])
  attribution            OrderAttribution?
  events                 OrderEvent[]
  items                  OrderItem[]
}

model MetaConfig {
  id          String   @id @default(cuid())
  productId   String   @unique
  pixelId     String?
  accessToken String?
  campaignId  String?
  adAccountId String?
  status      String   @default("INACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Conversation {
  id            String    @id @default(cuid())
  storeId       String
  externalId    String    @unique
  platform      String    @default("WHATSAPP")
  status        String    @default("OPEN")
  lastMessageAt DateTime  @default(now())
  agentPaused   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  store         Store     @relation(fields: [storeId], references: [id])
  messages      Message[]
}

model OrderEvent {
  id              String   @id @default(cuid())
  orderId         String
  timestamp       DateTime @default(now())
  source          String
  type            String
  externalEventId String?
  description     String
  payload         String?
  createdAt       DateTime @default(now())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, externalEventId])
}

model OrderAttribution {
  id            String   @id @default(cuid())
  orderId       String   @unique
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  fbclid        String?
  gclid         String?
  ttclid        String?
  landingSite   String?
  referringSite String?
  referrer      String?
  clientDetails String?
  rawNoteAttrs  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model FulfillmentRule {
  id               String  @id @default(cuid())
  storeId          String
  provider         String
  country          String  @default("ES")
  baseShippingCost Float   @default(0)
  returnCost       Float   @default(0)
  codFeeFixed      Float   @default(0)
  codFeePercent    Float   @default(0)
  packagingCost    Float   @default(0)
  handlingCost     Float   @default(0)
  taxPercent       Float   @default(0)
  extraZoneCost    String?
  isActive         Boolean @default(true)
  store            Store   @relation(fields: [storeId], references: [id])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String?
  sku          String?
  title        String
  variantTitle String?
  quantity     Int      @default(1)
  price        Float    @default(0)
  unitCost     Float    @default(0)
  totalPrice   Float    @default(0)
  isUpsell     Boolean  @default(false)
  product      Product? @relation(fields: [productId], references: [id])
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model BotMetric {
  id                   String   @id @default(cuid())
  storeId              String
  botId                String   @default("CLOWDBOT")
  messagesSent         Int      @default(0)
  conversationsStarted Int      @default(0)
  ordersAssisted       Int      @default(0)
  revenueAssisted      Float    @default(0)
  date                 DateTime @default(now())

  @@unique([storeId, botId, date])
}

model CompetitorLink {
  id        String   @id @default(cuid())
  productId String
  type      String
  url       String
  notes     String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model ResearchDocument {
  id        String   @id @default(cuid())
  productId String
  type      String
  title     String
  content   String?
  fileUrl   String?
  language  String   @default("es")
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model AvatarResearch {
  id                  String   @id @default(cuid())
  productId           String
  storeId             String?
  levelOfAwareness    String?
  desires             String?
  fears               String?
  sophistication      String?
  marketMood          String?
  whyItSells          String?
  mainDesire          String?
  angles              String?
  createdAt           DateTime @default(now())
  howTheyTalk         String?
  momentsOfPurchase   String?
  taboos              String?
  triedBefore         String?
  timelineHistoryJson String?
  product             Product  @relation(fields: [productId], references: [id])
  store               Store?   @relation(fields: [storeId], references: [id])
}

model ResearchSource {
  id           String    @id @default(cuid())
  productId    String
  url          String?
  content      String?
  type         String
  createdAt    DateTime  @default(now())
  citationText String?
  sourceDate   DateTime?
  product      Product   @relation(fields: [productId], references: [id])
}

model ResearchRun {
  id               String              @id @default(cuid())
  productId        String
  sessionId        String?
  status           String              @default("RUNNING")
  version          String              @default("V2")
  currentPhase     Int                 @default(0)
  progress         Int                 @default(0)
  logs             String?
  results          String?
  summary          String?
  avatarMatrix     String?
  awareness        String?
  marketMechanism  String?
  sophistication   String?
  objectionHeatmap String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @default(now()) @updatedAt
  copyContracts    CopyContract[]
  iterations       ResearchIteration[]
  session          ResearchSession?    @relation(fields: [sessionId], references: [id])
  product          Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([status])
}

model ResearchSession {
  id         String              @id @default(cuid())
  productId  String
  name       String
  configJson String?
  status     String              @default("OPEN")
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  iterations ResearchIteration[]
  runs       ResearchRun[]
  product    Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ResearchIteration {
  id        String          @id @default(cuid())
  sessionId String
  runId     String?
  version   Int             @default(1)
  changeLog String?
  dataJson  String?
  createdAt DateTime        @default(now())
  run       ResearchRun?    @relation(fields: [runId], references: [id])
  session   ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model FunnelAnalysis {
  id             String   @id @default(cuid())
  productId      String
  researchRunId  String?
  awarenessLevel String
  mechanismType  String
  strategyJson   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
