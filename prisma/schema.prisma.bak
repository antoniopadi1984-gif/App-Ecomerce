generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  name         String?
  password     String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  auditLogs    AuditLog[]
  stores       UserStoreAccess[]
  workSessions WorkSession[]
}

model UserStoreAccess {
  id      String @id @default(cuid())
  userId  String
  storeId String
  role    String @default("ATT")
  user    User   @relation(fields: [userId], references: [id])
  store   Store  @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
}

model Store {
  id                   String                  @id @default(cuid())
  name                 String
  domain               String?
  currency             String                  @default("EUR")
  brandKit             String?
  swipeFile            String?
  safeModeAds          Boolean                 @default(true)
  aggressiveLandings   Boolean                 @default(true)
  nomenclatureTemplate String                  @default("[PROD]_[CONC]_[VAR]_[LANG]")
  targetProfitMargin   Float                   @default(30.0)
  adSpendSource        String                  @default("MANUAL")
  adMetrics            AdMetricDaily[]
  agentActions         AgentAction[]
  agentCorrections     AgentCorrection[]
  agentProfiles        AgentProfile[]
  agentRuns            AgentRun[]
  aiBudgets            AiBudget[]
  aiUsageLogs          AiUsageLog[]
  auditLogs            AuditLog[]
  avatarProfiles       AvatarProfile[]
  research             AvatarResearch[]
  clowdbotConfig       ClowdbotConfig?
  connections          Connection[]
  contentAssets        ContentAsset[]
  contentCampaigns     ContentCampaign[]
  deliveryLogs         ContentDeliveryLog[]
  contentTemplates     ContentTemplate[]
  creativeAssets       CreativeAsset[]
  creativeBlueprints   CreativeBlueprint[]
  generatedCreatives   GeneratedCreative[]
  customers            Customer[]
  finances             DailyFinance[]
  snapshots            DailySnapshot[]
  expenses             Expense[]
  fulfillmentRules     FulfillmentRule[]
  historicalSheets     HistoricalSpreadsheet[]
  scenarios            HypothesisScenario[]
  landingProjects      LandingProject[]
  landingSections      LandingSection[]
  languageDictionaries LanguageDictionary[]
  ledgerEntries        LedgerEntry[]
  moderationRules      ModerationRule[]
  monthlyGoals         MonthlyGoal[]
  templates            NotificationTemplate[]
  orders               Order[]
  products             Product[]
  themes               ShopifyTheme[]
  socialAccounts       SocialAccount[]
  suppliers            Supplier[]
  thresholds           ThresholdConfig[]
  users                UserStoreAccess[]
  whatsappAccounts     WhatsAppAccount[]
  teamMembers          TeamMember[]
  aiLearnings          AiLearning[]
  driveRootFolderId    String?
}

model HistoricalSpreadsheet {
  id            String    @id @default(cuid())
  storeId       String
  name          String
  spreadsheetId String
  range         String    @default("Sheet1!A1:Z")
  status        String    @default("ACTIVE")
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  store         Store     @relation(fields: [storeId], references: [id])
}

model ShopifyTheme {
  id             String   @id @default(cuid())
  storeId        String
  name           String
  shopifyThemeId String?  @unique
  role           String   @default("UNSET")
  primaryColor   String?
  secondaryColor String?
  fontFamily     String?
  sectionsJson   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  store          Store    @relation(fields: [storeId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  storeId   String
  userId    String?
  action    String
  entity    String
  entityId  String
  oldValue  String?
  newValue  String?
  actorType String   @default("HUMAN")
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  store     Store    @relation(fields: [storeId], references: [id])
}

model WorkSession {
  id          String    @id @default(cuid())
  userId      String
  startTime   DateTime  @default(now())
  endTime     DateTime?
  duration    Int?
  cost        Float     @default(0)
  activityLog String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
}

model AiBudget {
  id            String   @id @default(cuid())
  storeId       String?
  scope         String   @default("GLOBAL")
  dailyLimitEur Float    @default(50.0)
  currentUsage  Float    @default(0.0)
  mode          String   @default("BALANCED")
  hardStop      Boolean  @default(false)
  lastResetAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  store         Store?   @relation(fields: [storeId], references: [id])
}

model AiUsageLog {
  id               String   @id @default(cuid())
  storeId          String?
  provider         String
  model            String
  taskType         String
  inputTokens      Int?
  outputTokens     Int?
  estimatedCostEur Float    @default(0)
  latencyMs        Int?
  status           String   @default("SUCCESS")
  error            String?
  createdAt        DateTime @default(now())
  store            Store?   @relation(fields: [storeId], references: [id])
}

model Supplier {
  id          String    @id @default(cuid())
  storeId     String
  name        String
  contactName String?
  email       String?
  phone       String?
  rating      Int?      @default(5)
  alias       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  store       Store     @relation(fields: [storeId], references: [id])
}

model Connection {
  id            String    @id @default(cuid())
  storeId       String
  provider      String
  apiKey        String?
  apiSecret     String?
  accessToken   String?
  webhookSecret String?
  webhookUrl    String?
  extraConfig   String?
  isActive      Boolean   @default(true)
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  store         Store     @relation(fields: [storeId], references: [id])

  @@unique([storeId, provider])
}

model Customer {
  id           String    @id @default(cuid())
  storeId      String
  name         String
  email        String?
  phone        String
  addressLine1 String?
  addressLine2 String?
  city         String?
  province     String?
  zip          String?
  country      String?
  totalOrders  Int       @default(0)
  totalSpent   Float     @default(0)
  avgTicket    Float     @default(0)
  tags         String?
  notes        String?
  lastOrderAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  store        Store     @relation(fields: [storeId], references: [id])
  orders       Order[]

  @@unique([storeId, phone])
  @@index([email])
}

model Product {
  id                String   @id @default(cuid())
  storeId           String
  shopifyId         String?  @unique
  title             String
  description       String?
  price             Float    @default(0)
  compareAtPrice    Float?
  imageUrl          String?
  variantId         String?
  sku               String?
  unitCost          Float?
  inventoryQuantity Int      @default(0)
  status            String   @default("ACTIVE")
  tags              String?
  productType       String?
  vendor            String?
  handle            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  supplierId        String?
  handlingCost      Float?   @default(0)
  returnCost        Float?   @default(0)
  shippingCost      Float?   @default(0)
  vatPercent        Float?   @default(21)
  country           String?  @default("ES")

  // Pricing & Economics
  desiredPrice  Float? // Precio de venta deseado
  pricingOffers String? // JSON array: diferentes ofertas/bundles
  breakevenROAS Float? // ROAS breakeven calculado
  breakevenCPC  Float? // CPC breakeven calculado
  targetMargin  Float?  @default(40) // Target margin %

  // URLs & Assets
  landingUrl          String? // Landing principal (backward compatibility)
  landingUrls         String? // JSON array: múltiples landings propias
  amazonLinks         String? // JSON array: enlaces de Amazon relacionados
  productImages       String? // JSON array: URLs de imágenes del producto
  competitorImages    String? // JSON array: URLs de imágenes de competencia
  niche               String?
  productFamily       String? // Familia del producto: "Suplementos", "Skincare", "Software", etc.
  problemToSolve      String?
  driveFolderId       String?
  driveRootPath       String? // JSON: FolderStructure completa
  avatarResearches    AvatarResearch[]
  competitorLandings  CompetitorLanding?
  competitorLinks     CompetitorLink[]
  assets              ContentAsset[]
  templates           ContentTemplate[]
  copyArtifacts       CopyArtifact[]
  copyContracts       CopyContract[]
  copyJobs            CopyJob[]
  creativeAssets      CreativeAsset[]
  blueprints          CreativeBlueprint[]
  creativeProjects    CreativeProject[]
  driveAssets         DriveAsset[]
  evidenceChunks      EvidenceChunk[]
  knowledgeNodes      KnowledgeNode[]
  landingProjects     LandingProject[]
  dictionaries        LanguageDictionary[]
  angles              MarketingAngle[]
  itemOf              OrderItem[]
  pageBlueprints      PageBlueprint[]
  supplier            Supplier?              @relation(fields: [supplierId], references: [id])
  store               Store                  @relation(fields: [storeId], references: [id])
  finance             ProductFinance?
  maturity            ProductMaturity?
  documents           ResearchDocument[]
  researchProjects    ResearchProject[]
  researchRuns        ResearchRun[]
  researchSources     ResearchSource[]
  searchQueries       SearchQuery[]
  videoClips          VideoClip[]
  videoJobs           VideoJob[]
  videoAssets         VideoAsset[] // NEW: Uploaded videos with metadata removed
  videoScripts        VideoScript[] // NEW: Extracted scripts from videos
  vocQuotes           VoiceOfCustomerQuote[]
  adCopies            AdCopy[]
  // Creative System
  avatars             Avatar[]
  creatives           Creative[]
  scriptLibrary       ScriptLibrary[]
  GeneratedCreative   GeneratedCreative[]
  VOCInsight          VOCInsight[]
  CompetitiveAnalysis CompetitiveAnalysis[]
  OfferStack          OfferStack[]
}

model Order {
  id                     String               @id @default(cuid())
  storeId                String
  customerId             String?
  shopifyId              String?              @unique
  orderNumber            String?
  orderType              String               @default("REGULAR")
  abandonedId            String?              @unique
  draftId                String?              @unique
  customerName           String?
  customerEmail          String?
  customerPhone          String?
  customerIp             String?
  userAgent              String?
  addressLine1           String?
  addressLine2           String?
  city                   String?
  province               String?
  zip                    String?
  country                String?
  addressStatus          String               @default("PENDING")
  correctedAddress       String?
  geolocation            String?
  lat                    Float?
  lng                    Float?
  totalPrice             Float                @default(0)
  totalTax               Float                @default(0)
  shippingCost           Float                @default(0)
  paymentMethod          String               @default("COD")
  financialStatus        String?
  currency               String               @default("EUR")
  discounts              Float                @default(0)
  discountCode           String?
  status                 String               @default("PENDING")
  fulfillmentStatus      String?
  carrier                String?
  trackingCode           String?
  shippedAt              DateTime?
  deliveredAt            DateTime?
  returnedAt             DateTime?
  returnReason           String?
  estimatedLogisticsCost Float                @default(0)
  warehouse              String?
  priority               String?
  logisticsProvider      String?
  trackingUrl            String?
  logisticsStatus        String?
  finalStatus            String?
  confirmationDate       DateTime?
  confirmationAttempts   Int                  @default(0)
  incidenceResult        String?
  incidenceReason        String?
  incidenceAttempts      Int                  @default(0)
  needsReview            Boolean              @default(false)
  productTitle           String?
  variantTitle           String?
  sku                    String?
  units                  Int                  @default(1)
  assignedAgentId        String?
  processedAt            DateTime?
  incidenciaType         String?
  notes                  String?
  shopifyNote            String?
  tags                   String?
  whatsappSent           Boolean              @default(false)
  msgConfirmationSent    Boolean              @default(false)
  msgTrackingSent        Boolean              @default(false)
  msgDeliverySent        Boolean              @default(false)
  msgIncidenceSent       Boolean              @default(false)
  callAttempt1           String?
  callAttempt2           String?
  callAttempt3           String?
  callRecordingUrl       String?
  phoneValidated         Boolean              @default(false)
  source                 String?
  medium                 String?
  campaign               String?
  content                String?
  term                   String?
  adsetId                String?
  adId                   String?
  rawJson                String?
  shopifyUpdatedAt       DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  estimatedProfit        Float?
  realProfit             Float?
  riskScore              Int                  @default(0)
  riskLevel              String               @default("LOW")
  deliveryLogs           ContentDeliveryLog[]
  messages               Message[]
  store                  Store                @relation(fields: [storeId], references: [id])
  customer               Customer?            @relation(fields: [customerId], references: [id])
  attribution            OrderAttribution?
  events                 OrderEvent[]
  items                  OrderItem[]
}

model OrderEvent {
  id              String   @id @default(cuid())
  orderId         String
  timestamp       DateTime @default(now())
  source          String
  type            String
  externalEventId String?
  description     String
  payload         String?
  createdAt       DateTime @default(now())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, externalEventId])
}

model OrderAttribution {
  id            String   @id @default(cuid())
  orderId       String   @unique
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  fbclid        String?
  gclid         String?
  ttclid        String?
  landingSite   String?
  referringSite String?
  referrer      String?
  clientDetails String?
  rawNoteAttrs  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model FulfillmentRule {
  id               String  @id @default(cuid())
  storeId          String
  provider         String
  country          String  @default("ES")
  baseShippingCost Float   @default(0)
  returnCost       Float   @default(0)
  codFeeFixed      Float   @default(0)
  codFeePercent    Float   @default(0)
  packagingCost    Float   @default(0)
  handlingCost     Float   @default(0)
  taxPercent       Float   @default(0)
  extraZoneCost    String?
  isActive         Boolean @default(true)
  store            Store   @relation(fields: [storeId], references: [id])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String?
  sku          String?
  title        String
  variantTitle String?
  quantity     Int      @default(1)
  price        Float    @default(0)
  unitCost     Float    @default(0)
  totalPrice   Float    @default(0)
  isUpsell     Boolean  @default(false)
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id])
}

model BotMetric {
  id                   String   @id @default(cuid())
  storeId              String
  botId                String   @default("CLOWDBOT")
  messagesSent         Int      @default(0)
  conversationsStarted Int      @default(0)
  ordersAssisted       Int      @default(0)
  revenueAssisted      Float    @default(0)
  date                 DateTime @default(now())

  @@unique([storeId, botId, date])
}

model CompetitorLink {
  id        String   @id @default(cuid())
  productId String
  type      String
  url       String
  notes     String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model ResearchDocument {
  id        String   @id @default(cuid())
  productId String
  type      String
  title     String
  content   String?
  fileUrl   String?
  language  String   @default("es")
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model AvatarResearch {
  id                  String   @id @default(cuid())
  productId           String
  storeId             String?
  levelOfAwareness    String?
  desires             String?
  fears               String?
  sophistication      String?
  marketMood          String?
  whyItSells          String?
  mainDesire          String?
  angles              String?
  createdAt           DateTime @default(now())
  howTheyTalk         String?
  momentsOfPurchase   String?
  taboos              String?
  triedBefore         String?
  timelineHistoryJson String?
  store               Store?   @relation(fields: [storeId], references: [id])
  product             Product  @relation(fields: [productId], references: [id])
}

model ResearchSource {
  id           String    @id @default(cuid())
  productId    String
  url          String?
  content      String?
  type         String
  createdAt    DateTime  @default(now())
  citationText String?
  sourceDate   DateTime?
  product      Product   @relation(fields: [productId], references: [id])
}

model ResearchRun {
  id               String         @id @default(cuid())
  productId        String
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  status           String         @default("RUNNING")
  version          String         @default("V2")
  currentPhase     Int            @default(0)
  progress         Int            @default(0)
  logs             String? // Manual string appending for SQLite
  results          String?
  summary          String?
  avatarMatrix     String?
  awareness        String?
  marketMechanism  String?
  sophistication   String?
  objectionHeatmap String?
  copyContracts    CopyContract[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([productId])
  @@index([status])
}

model CopyContract {
  id                    String            @id @default(cuid())
  productId             String
  researchRunId         String?
  avatarSegment         String
  awarenessLevel        String
  sophistication        String
  mainAngle             String
  dreamOutcome          String?
  perceivedProb         String?
  timeDelay             String?
  effortSacrifice       String?
  psychologicalTriggers String?
  promisesAllowed       String?
  promisesProhibited    String?
  objectionToKill       String?
  proofRequired         String?
  ctaAllowed            String?
  tone                  String?
  status                String            @default("ACTIVE")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  researchRun           ResearchRun?      @relation(fields: [researchRunId], references: [id])
  product               Product           @relation(fields: [productId], references: [id])
  creativeProjects      CreativeProject[]
}

model CompetitorLanding {
  id                String   @id @default(cuid())
  productId         String   @unique
  url               String
  screenshotUrl     String?
  type              String?
  avatar            String?
  awareness         String?
  angle             String?
  promise           String?
  objectionsTreated String?
  structureJson     String?
  cta               String?
  risks             String?
  opportunityScore  Float?
  status            String   @default("DETECTED")
  createdAt         DateTime @default(now())
  product           Product  @relation(fields: [productId], references: [id])
}

model VoiceOfCustomerQuote {
  id              String   @id @default(cuid())
  productId       String
  text            String
  category        String
  sourceUrl       String?
  createdAt       DateTime @default(now())
  citationText    String?
  evidenceContext String?
  product         Product  @relation(fields: [productId], references: [id])
}

model MarketingAngle {
  id                String   @id @default(cuid())
  productId         String
  title             String
  hook              String
  benefit           String
  proof             String
  objection         String
  cta               String
  awarenessLevel    String?
  isWinner          Boolean  @default(false)
  saturationScore   Float?
  status            String   @default("OPPORTUNITY")
  sourceBlueprintId String?
  createdAt         DateTime @default(now())
  product           Product  @relation(fields: [productId], references: [id])
}

model CreativeAsset {
  id           String              @id @default(cuid())
  productId    String
  storeId      String?
  type         String
  name         String
  driveUrl     String?
  nomenclatura String?
  editor       String?
  angulo       String?
  language     String              @default("es")
  spend        Float               @default(0)
  revenue      Float               @default(0)
  purchases    Int                 @default(0)
  hookRate     Float?
  ctr          Float?
  verdict      String?
  createdAt    DateTime            @default(now())
  store        Store?              @relation(fields: [storeId], references: [id])
  product      Product             @relation(fields: [productId], references: [id])
  dailyStats   CreativeDailyStat[]
}

model CreativeProject {
  id                      String           @id @default(cuid())
  name                    String
  productId               String?
  platform                String?          @default("TIKTOK")
  language                String           @default("es")
  status                  String           @default("DRAFT")
  timelineState           String
  thumbnail               String?
  duration                Int              @default(0)
  aspectRatio             String           @default("9:16")
  magicHook               String?
  dissectionJson          String?
  variationsJson          String?
  sourceUrl               String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  blueprintId             String?
  contractId              String?
  avatarId                String?
  qualityGateResultsJson  String?
  variantScoresJson       String?
  researchVersionId       String?
  selectedAvatarJson      String?
  selectedDesireJson      String?
  bigIdea                 String?
  uniqueMechanism         String?
  transformationalPromise String?
  mainAngleJson           String?
  researchVersion         ResearchVersion? @relation(fields: [researchVersionId], references: [id])
  avatar                  AvatarProfile?   @relation(fields: [avatarId], references: [id])
  product                 Product?         @relation(fields: [productId], references: [id])
  contract                CopyContract?    @relation(fields: [contractId], references: [id])
  maestroAssets           MaestroAsset[]
  maestroScripts          MaestroScript[]
  maestroVariants         MaestroVariant[]
}

model MaestroAsset {
  id        String           @id @default(cuid())
  projectId String
  type      String
  source    String
  url       String
  status    String           @default("PROCESSING")
  metadata  String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  project   CreativeProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clips     MaestroClip[]
  variants  MaestroVariant[]
}

model MaestroClip {
  id         String       @id @default(cuid())
  assetId    String
  kind       String
  startTime  Float
  endTime    Float
  transcript String?
  score      Float?
  createdAt  DateTime     @default(now())
  asset      MaestroAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model MaestroScript {
  id         String          @id @default(cuid())
  projectId  String
  version    Int             @default(1)
  language   String          @default("es")
  content    String
  isApproved Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  project    CreativeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model MaestroVariant {
  id            String          @id @default(cuid())
  projectId     String
  name          String
  recipeJson    String
  outputAssetId String?
  status        String          @default("QUEUED")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  outputAsset   MaestroAsset?   @relation(fields: [outputAssetId], references: [id])
  project       CreativeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model LandingProject {
  id                  String   @id @default(cuid())
  storeId             String
  productId           String?
  name                String
  url                 String?
  status              String   @default("DRAFT")
  blocksJson          String?
  styleJson           String?
  versionsCount       Int      @default(1)
  previousVersionJson String?
  changeLogJson       String?
  blueprintId         String?
  store               Store    @relation(fields: [storeId], references: [id])
  product             Product? @relation(fields: [productId], references: [id])
}

model AvatarProfile {
  id             String            @id @default(cuid())
  storeId        String
  name           String
  sex            String
  ageRange       String?
  region         String?
  imageUrl       String?
  videoUrl       String?
  status         String            @default("DRAFT")
  lastError      String?
  evolutionId    String?
  evolutionStage String?
  metadataJson   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  assets         AvatarAsset[]
  store          Store             @relation(fields: [storeId], references: [id])
  projects       CreativeProject[]
}

model AvatarAsset {
  id              String        @id @default(cuid())
  avatarProfileId String
  type            String        @default("AVATAR_IMAGE")
  pathLocal       String
  mime            String?
  width           Int?
  height          Int?
  driveFileId     String?
  createdAt       DateTime      @default(now())
  avatarProfile   AvatarProfile @relation(fields: [avatarProfileId], references: [id], onDelete: Cascade)
}

model ProductFinance {
  id                   String   @id @default(cuid())
  productId            String   @unique
  unitCost             Float    @default(0)
  sellingPrice         Float    @default(0)
  shippingCost         Float    @default(0)
  returnCost           Float    @default(0)
  taxes                Float    @default(0)
  isUpsell             Boolean  @default(false)
  targetCPA            Float?
  expectedDeliveryRate Float    @default(0.85)
  updatedAt            DateTime @updatedAt
  product              Product  @relation(fields: [productId], references: [id])
}

model PricingOffer {
  id              String   @id @default(cuid())
  storeId         String
  productId       String?
  offerName       String
  productName     String
  salePrice       Float    @default(0)
  productCost     Float    @default(0)
  iva             Float    @default(0)
  shippingCost    Float    @default(0)
  codFee          Float    @default(0)
  shipmentRate    Float    @default(80)
  deliveryRate    Float    @default(70)
  maxCpa          Float    @default(0)
  roasBreakeven   Float    @default(0)
  grossProfit     Float    @default(0)
  effectiveProfit Float    @default(0)
  marginPercent   Float    @default(0)
  roi             Float    @default(0)
  isActive        Boolean  @default(true)
  driveFolderId   String?
  driveDocId      String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PromptTemplate {
  id           String   @id @default(cuid())
  name         String   @unique
  modelTarget  String   @default("GEMINI")
  content      String
  placeholders String?
  version      Int      @default(1)
  category     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PageBlueprint {
  id            String   @id @default(cuid())
  productId     String
  researchRunId String?
  type          String
  name          String
  sectionsJson  String?
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  product       Product  @relation(fields: [productId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  storeId     String
  date        DateTime
  amount      Float
  category    String
  description String?
  store       Store    @relation(fields: [storeId], references: [id])
}

model DailyFinance {
  id                       String   @id @default(cuid())
  storeId                  String
  date                     DateTime
  adSpend                  Float    @default(0)
  visitors                 Int      @default(0)
  cogs                     Float    @default(0)
  shippingCost             Float    @default(0)
  totalRevenue             Float    @default(0)
  netProfit                Float    @default(0)
  ordersCount              Int      @default(0)
  deliveredCount           Int      @default(0)
  returnedCount            Int      @default(0)
  cancelledCount           Int      @default(0)
  incidencesCount          Int      @default(0)
  recoveredIncidencesCount Int      @default(0)
  communicationCost        Float    @default(0)
  store                    Store    @relation(fields: [storeId], references: [id])

  @@unique([storeId, date])
}

model HypothesisScenario {
  id           String @id @default(cuid())
  storeId      String
  name         String
  targetProfit Float
  productCost  Float
  shippingCost Float
  targetCPA    Float?
  targetROAS   Float?
  store        Store  @relation(fields: [storeId], references: [id])
}

model NotificationTemplate {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  trigger   String
  channel   String
  body      String
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id])
}

model ClowdbotConfig {
  id                     String   @id @default(cuid())
  storeId                String   @unique
  isActive               Boolean  @default(false)
  agentName              String   @default("Clowdbot")
  agentRole              String   @default("Especialista en Atención al Cliente")
  agentEmail             String   @default("admin@ecombom.com")
  smtpHost               String?
  smtpPort               Int?
  smtpUser               String?
  smtpPass               String?
  knowledgeBase          String?
  roleKnowledge          String?
  channels               String   @default("WHATSAPP,EMAIL")
  humanInterventionAlert Boolean  @default(true)
  notificationWebhook    String?
  isFinancialExpert      Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  store                  Store    @relation(fields: [storeId], references: [id])
}

model WhatsAppAccount {
  id                String    @id @default(cuid())
  storeId           String
  name              String    @default("WhatsApp Principal")
  type              String    @default("API")
  phoneNumber       String?
  accessToken       String?
  phoneId           String?
  businessAccountId String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  messages          Message[]
  store             Store     @relation(fields: [storeId], references: [id])
}

model Message {
  id                String           @id @default(cuid())
  orderId           String?
  customerContact   String
  sender            String
  content           String
  channel           String           @default("WHATSAPP")
  whatsappAccountId String?
  isRead            Boolean          @default(false)
  status            String           @default("SENT")
  cost              Float            @default(0)
  timestamp         DateTime         @default(now())
  createdAt         DateTime         @default(now())
  order             Order?           @relation(fields: [orderId], references: [id])
  whatsappAccount   WhatsAppAccount? @relation(fields: [whatsappAccountId], references: [id])
}

model AdSpyCapture {
  id            String   @id @default(cuid())
  type          String
  platform      String
  url           String
  cleanedUrl    String?
  originalUrl   String?
  title         String?
  metadata      String?
  captureMethod String   @default("direct")
  sttScript     String?
  status        String   @default("INBOX")
  createdAt     DateTime @default(now())
}

model LedgerEntry {
  id          String   @id @default(cuid())
  storeId     String
  orderId     String?
  date        DateTime @default(now())
  type        String
  category    String
  amount      Float
  description String?
  metadata    String?
  createdAt   DateTime @default(now())
  store       Store    @relation(fields: [storeId], references: [id])
}

model Job {
  id          String    @id @default(cuid())
  type        String
  status      String    @default("PENDING")
  payload     String?
  result      String?
  progress    Int       @default(0)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  lockedAt    DateTime?
  lastError   String?
  runAt       DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AdMetricDaily {
  id           String   @id @default(cuid())
  storeId      String
  date         DateTime
  platform     String
  level        String
  externalId   String
  name         String?
  metricsRaw   String
  metricsNorm  String
  window       String   @default("DAY")
  isActive     Boolean  @default(true)
  completeness String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  store        Store    @relation(fields: [storeId], references: [id])

  @@unique([storeId, platform, level, externalId, date, window], map: "unique_ad_metric_window")
}

model CreativeDailyStat {
  id                 String        @id @default(cuid())
  creativeAssetId    String
  date               DateTime
  spend              Float         @default(0)
  impressions        Int           @default(0)
  clicks             Int           @default(0)
  video_3s_views     Int           @default(0)
  video_50pct_views  Int           @default(0)
  landing_page_views Int           @default(0)
  add_to_cart        Int           @default(0)
  initiate_checkout  Int           @default(0)
  purchases          Int           @default(0)
  revenue            Float         @default(0)
  delivered_orders   Int           @default(0)
  real_revenue       Float         @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  creativeAsset      CreativeAsset @relation(fields: [creativeAssetId], references: [id])

  @@unique([creativeAssetId, date])
}

model SocialAccount {
  id             String       @id @default(cuid())
  storeId        String
  platform       String
  externalId     String
  name           String
  pictureUrl     String?
  moderationMode String       @default("MANUAL")
  accessToken    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  store          Store        @relation(fields: [storeId], references: [id])
  posts          SocialPost[]

  @@unique([storeId, platform, externalId])
}

model SocialPost {
  id              String          @id @default(cuid())
  socialAccountId String
  externalId      String          @unique
  permalink       String?
  caption         String?
  type            String?
  rawJson         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  comments        SocialComment[]
  socialAccount   SocialAccount   @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
}

model SocialComment {
  id         String         @id @default(cuid())
  postId     String
  externalId String         @unique
  parentId   String?
  authorName String
  authorId   String
  message    String
  sentiment  String?
  intent     String?
  severity   String         @default("LOW")
  status     String         @default("VISIBLE")
  isReplied  Boolean        @default(false)
  rawJson    String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  actions    SocialAction[]
  post       SocialPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model SocialAction {
  id         String        @id @default(cuid())
  commentId  String
  type       String
  actorType  String
  userId     String?
  payload    String?
  externalId String?
  createdAt  DateTime      @default(now())
  comment    SocialComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model ModerationRule {
  id         String   @id @default(cuid())
  storeId    String
  name       String
  enabled    Boolean  @default(true)
  conditions String
  actions    String
  priority   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  store      Store    @relation(fields: [storeId], references: [id])
}

model AgentProfile {
  id           String        @id @default(cuid())
  storeId      String
  name         String
  role         String        @default("MEDIA_BUYING")
  instructions String        @default("")
  tone         String        @default("professional")
  channels     String        @default("[]")
  menus        String        @default("[]")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  actions      AgentAction[]
  store        Store         @relation(fields: [storeId], references: [id])
  runs         AgentRun[]
}

model ThresholdConfig {
  id               String          @id @default(cuid())
  storeId          String
  type             String          @default("GLOBAL")
  scenarioName     String?
  version          Int             @default(1)
  validFrom        DateTime        @default(now())
  validTo          DateTime?
  minProfitPercent Float           @default(20.0)
  minRoas          Float           @default(0.0)
  minDeliveryRate  Float           @default(0.0)
  minConfirmRate   Float           @default(0.0)
  maxIncidenceRate Float           @default(100.0)
  minRecoveryRate  Float           @default(0.0)
  maxReturnRate    Float           @default(100.0)
  maxCpc           Float?
  maxCpa           Float?
  criticalKpis     String?         @default("[]")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  snapshots        DailySnapshot[]
  store            Store           @relation(fields: [storeId], references: [id])
}

model DailySnapshot {
  id               String           @id @default(cuid())
  storeId          String
  date             DateTime
  view             String           @default("ORDERS_CREATED")
  thresholdId      String?
  spendAds         Float            @default(0)
  revenueReal      Float            @default(0)
  costsReal        Float            @default(0)
  netProfit        Float            @default(0)
  roasReal         Float            @default(0)
  deliveryRate     Float            @default(0)
  incidenceRate    Float            @default(0)
  status           String           @default("NEUTRAL")
  isComplete       Boolean          @default(false)
  metricsJson      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  dataCompleteness String?          @default("{}")
  threshold        ThresholdConfig? @relation(fields: [thresholdId], references: [id])
  store            Store            @relation(fields: [storeId], references: [id])

  @@unique([storeId, date, view])
}

model ProviderStatusMap {
  id               String   @id @default(cuid())
  provider         String
  rawStatus        String
  normalizedStatus String
  labelEs          String
  severity         String
  isFinal          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([provider, rawStatus])
}

model MonthlyGoal {
  id                String   @id @default(cuid())
  storeId           String
  month             Int
  year              Int
  adSpendBudget     Float    @default(0)
  targetRoas        Float    @default(0)
  breakevenRoas     Float    @default(0)
  maxCpa            Float    @default(0)
  maxCpc            Float    @default(0)
  expectedConvRate  Float    @default(0)
  expectedAvgTicket Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  store             Store    @relation(fields: [storeId], references: [id])

  @@unique([storeId, month, year])
}

model SystemHeartbeat {
  id        String   @id @default("singleton")
  timestamp DateTime @updatedAt
  status    String   @default("OK")
}

model AgentRun {
  id             String        @id @default(cuid())
  agentProfileId String
  storeId        String
  context        String?
  input          String        @default("")
  output         String        @default("")
  latency        Int?
  status         String        @default("SUCCESS")
  error          String?
  createdAt      DateTime      @default(now())
  actions        AgentAction[]
  agent          AgentProfile  @relation(fields: [agentProfileId], references: [id])
  store          Store         @relation(fields: [storeId], references: [id])
}

model AgentAction {
  id             String        @id @default(cuid())
  agentRunId     String?
  agentProfileId String?
  storeId        String
  actorType      String        @default("IA")
  actorId        String?
  actionType     String
  details        String?
  impactMetric   String?
  impactValue    Float?
  createdAt      DateTime      @default(now())
  run            AgentRun?     @relation(fields: [agentRunId], references: [id])
  agent          AgentProfile? @relation(fields: [agentProfileId], references: [id])
  store          Store         @relation(fields: [storeId], references: [id])
}

model ContentTemplate {
  id          String         @id @default(cuid())
  storeId     String
  name        String
  type        String
  description String?
  configJson  String
  productId   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  assets      ContentAsset[]
  store       Store          @relation(fields: [storeId], references: [id])
  product     Product?       @relation(fields: [productId], references: [id])
}

model ContentAsset {
  id           String               @id @default(cuid())
  storeId      String
  templateId   String?
  productId    String?
  name         String
  fileUrl      String
  type         String
  metadataJson String?
  createdAt    DateTime             @default(now())
  store        Store                @relation(fields: [storeId], references: [id])
  template     ContentTemplate?     @relation(fields: [templateId], references: [id])
  product      Product?             @relation(fields: [productId], references: [id])
  deliveries   ContentDeliveryLog[]
  lessons      CourseLesson[]
}

model CourseLesson {
  id       String       @id @default(cuid())
  assetId  String
  title    String
  videoUrl String?
  audioUrl String?
  content  String?
  duration Int?
  order    Int          @default(0)
  course   ContentAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model ContentCampaign {
  id              String   @id @default(cuid())
  storeId         String
  name            String
  triggerEvent    String
  assetId         String
  isActive        Boolean  @default(true)
  requireApproval Boolean  @default(true)
  conditionsJson  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  store           Store    @relation(fields: [storeId], references: [id])
}

model ContentDeliveryLog {
  id      String       @id @default(cuid())
  storeId String
  orderId String
  assetId String
  sentAt  DateTime     @default(now())
  channel String       @default("WHATSAPP")
  status  String       @default("SENT")
  error   String?
  store   Store        @relation(fields: [storeId], references: [id])
  order   Order        @relation(fields: [orderId], references: [id])
  asset   ContentAsset @relation(fields: [assetId], references: [id])
}

model CreativeBlueprint {
  id                String   @id @default(cuid())
  storeId           String
  productId         String
  avatarSegment     String?
  levelOfAwareness  String?
  mainAngle         String?
  secondaryAngles   String?
  centralClaim      String?
  criticalObjection String?
  recommendedCTA    String?
  complianceRisks   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  store             Store    @relation(fields: [storeId], references: [id])
  product           Product  @relation(fields: [productId], references: [id])
}

model LanguageDictionary {
  id            String   @id @default(cuid())
  storeId       String
  productId     String
  terms         String
  negativeTerms String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  store         Store    @relation(fields: [storeId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])
}

model LandingSection {
  id              String   @id @default(cuid())
  storeId         String
  name            String
  type            String
  awarenessLevel  String?
  usageGuidelines String?
  configJson      String
  examplesJson    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  store           Store    @relation(fields: [storeId], references: [id])
}

model KnowledgeNode {
  id            String          @id @default(cuid())
  productId     String
  type          String
  contentJson   String
  metadataJson  String?
  createdAt     DateTime        @default(now())
  outgoingLinks KnowledgeLink[] @relation("NodeSource")
  incomingLinks KnowledgeLink[] @relation("NodeTarget")
  product       Product         @relation(fields: [productId], references: [id])
}

model KnowledgeLink {
  id           String        @id @default(cuid())
  sourceId     String
  targetId     String
  relationType String
  strength     Float         @default(1.0)
  explanation  String?
  createdAt    DateTime      @default(now())
  source       KnowledgeNode @relation("NodeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target       KnowledgeNode @relation("NodeTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model VideoClip {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  // NEW: Optional relation to VideoAsset (for clips from uploaded videos)
  videoAssetId String?
  videoAsset   VideoAsset? @relation(fields: [videoAssetId], references: [id], onDelete: Cascade)

  // Existing fields (backward compatibility)
  type         String // Type of clip
  url          String // URL or Drive ID
  scriptText   String? // Legacy script field
  duration     Int? // Duration in seconds (as Int for backward compatibility)
  metadataJson String? // Additional metadata

  // NEW: Enhanced fields for auto-detected clips
  startTime      Float? // Start time in seconds
  endTime        Float? // End time in seconds
  clipNumber     Int? // Sequential number
  score          Float? // Quality score (0-1)
  exportedFormat String? // "9:16", "16:9", "1:1"
  status         String? // DETECTED, SELECTED, EXPORTED
  isUserSelected Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@index([productId])
  @@index([videoAssetId])
}

model VideoJob {
  id          String   @id @default(cuid())
  productId   String
  type        String
  status      String   @default("PENDING")
  payloadJson String?
  resultUrl   String?
  progress    Int      @default(0)
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id])
}

model AgentCorrection {
  id               String   @id @default(cuid())
  storeId          String
  agentProfileId   String?
  originalContext  String?
  originalResponse String?
  humanCorrection  String
  reasoning        String?
  learnedAt        DateTime @default(now())
  store            Store    @relation(fields: [storeId], references: [id])
}

model ProductMaturity {
  id               String   @id @default(cuid())
  productId        String   @unique
  scoresJson       String
  lastCalculatedAt DateTime @default(now())
  product          Product  @relation(fields: [productId], references: [id])
}

model CopyJob {
  id             String                 @id @default(cuid())
  productId      String
  type           String
  status         String                 @default("PENDING")
  requestPayload String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  links          CopyConversationLink[]
  product        Product                @relation(fields: [productId], references: [id])
}

model CopyArtifact {
  id        String                 @id @default(cuid())
  productId String
  type      String
  version   Int                    @default(1)
  source    String                 @default("CLAUDE")
  content   String
  status    String                 @default("READY")
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  product   Product                @relation(fields: [productId], references: [id])
  links     CopyConversationLink[]
}

model CopyConversationLink {
  id         String        @id @default(cuid())
  jobId      String?
  artifactId String?
  notes      String?
  tags       String?
  createdAt  DateTime      @default(now())
  artifact   CopyArtifact? @relation(fields: [artifactId], references: [id])
  job        CopyJob?      @relation(fields: [jobId], references: [id])
}

model SearchQuery {
  id           String         @id @default(cuid())
  productId    String
  query        String
  provider     String
  status       String         @default("PENDING")
  resultsCount Int            @default(0)
  createdAt    DateTime       @default(now())
  product      Product        @relation(fields: [productId], references: [id])
  results      SearchResult[]
}

model SearchResult {
  id          String          @id @default(cuid())
  queryId     String
  url         String
  title       String
  snippet     String?
  content     String?
  score       Float?
  publishedAt DateTime?
  provider    String
  createdAt   DateTime        @default(now())
  evidence    EvidenceChunk[]
  query       SearchQuery     @relation(fields: [queryId], references: [id], onDelete: Cascade)
}

model EvidenceChunk {
  id             String        @id @default(cuid())
  productId      String
  searchResultId String?
  content        String
  citation       String?
  category       String?
  confidence     Float?
  createdAt      DateTime      @default(now())
  searchResult   SearchResult? @relation(fields: [searchResultId], references: [id])
  product        Product       @relation(fields: [productId], references: [id])
}

model DriveAsset {
  id          String   @id @default(cuid())
  productId   String
  driveFileId String   @unique
  drivePath   String
  assetType   String
  sourceUrl   String?
  createdAt   DateTime @default(now())
  createdBy   String?
  product     Product  @relation(fields: [productId], references: [id])

  @@index([productId, assetType])
}

// ============================================
// RESEARCH SYSTEM
// ============================================

model ResearchProject {
  id              String  @id @default(cuid())
  productId       String  @unique
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  brandName       String
  productName     String
  status          String  @default("PENDING")
  latestVersionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  versions ResearchVersion[]

  @@index([productId])
}

model ResearchVersion {
  id               String          @id @default(cuid())
  projectId        String
  project          ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionNumber    Int
  summaryOfChanges String?

  createdAt DateTime @default(now())

  outputs          ResearchOutput?
  creativeProjects CreativeProject[]
  adCopies         AdCopy[]

  @@unique([projectId, versionNumber])
  @@index([projectId])
}

model ResearchOutput {
  id        String          @id @default(cuid())
  versionId String          @unique
  version   ResearchVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  macroAvatarSheet         String?
  languageBank             String?
  productIntelligence      String?
  competitorBreakdown      String?
  creativeInsights         String?
  economicsJson            String?
  marketSophisticationJson String?
  competitorIntelJson      String?
  hookAngleDb              String?
  validationReport         String?
  exportsMarkdown          String?
  exportsJson              String?

  createdAt DateTime @default(now())

  @@index([versionId])
}

model SourceDocument {
  id              String   @id @default(cuid())
  projectId       String
  type            String
  url             String
  title           String?
  rawText         String?
  retrievedAt     DateTime
  credibilityTier String?

  createdAt DateTime @default(now())

  @@index([projectId])
}

model TeamMember {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  email   String
  role    String

  createdAt DateTime @default(now())

  @@index([storeId])
}

model AdCopy {
  id                String   @id @default(cuid())
  productId         String
  researchVersionId String?
  avatarId          String?
  angle             String?
  framework         String? // 'research-reveal', 'shocking-confession', etc.
  type              String // 'SALES_LETTER', 'STORY_LEAD', 'SHORT_FRAMEWORK'
  content           String
  status            String   @default("DRAFT")
  createdAt         DateTime @default(now())

  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  researchVersion ResearchVersion? @relation(fields: [researchVersionId], references: [id], onDelete: SetNull)
}

model AiLearning {
  id          String   @id @default(cuid())
  storeId     String
  insights    String
  winnerCount Int      @default(0)
  loserCount  Int      @default(0)
  date        DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

// ============================================
// VIDEO ASSET MODELS
// User-uploaded videos with metadata removal and clip extraction
// ============================================

model VideoAsset {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // File info
  fileName    String
  driveFileId String // Google Drive file ID

  // Video properties
  duration   Float? // Duration in seconds
  resolution String? // JSON: {width, height}
  fps        Float? // Frames per second

  // Size tracking
  originalSize Int? // Original file size (bytes)
  cleanSize    Int? // Size after metadata removal

  // Processing status
  hasMetadata Boolean @default(true)
  status      String  @default("UPLOADED") // UPLOADED, ANALYZING, READY, FAILED

  // Relations
  clips   VideoClip[]
  scripts VideoScript[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([status])
}

model VideoScript {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  videoAssetId String?
  videoAsset   VideoAsset? @relation(fields: [videoAssetId], references: [id], onDelete: Cascade)

  // Script content
  transcript     String // Full transcript
  timestampsJson String? // JSON: [{time: number, text: string}]

  // Language
  language String @default("es")

  // Drive export
  driveFileId String? // If exported to Drive

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([videoAssetId])
}

// ==========================================
// CREATIVE SYSTEM MODELS
// ==========================================

// Avatar for video creatives (HeyGen alternative)
model Avatar {
  id               String     @id @default(cuid())
  productId        String?
  product          Product?   @relation(fields: [productId], references: [id])
  name             String
  type             String // RESEARCH_BASED, CUSTOM
  // Appearance
  gender           String?
  age              Int?
  ethnicity        String?
  styleJson        String? // Hair, clothing, accessories
  // Voice
  voiceId          String? // ElevenLabs voice ID
  language         String     @default("es")
  tone             String? // professional, friendly, energetic
  // Assets
  avatarImageUrl   String? // Base image
  avatarModelUrl   String? // 3D model if available
  // Research data
  researchDataJson String? // Avatar persona from research
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  creatives        Creative[]

  @@index([productId])
  @@index([type])
}

// Unified creative asset (video, static, carousel)
model Creative {
  id               String   @id @default(cuid())
  productId        String
  product          Product  @relation(fields: [productId], references: [id])
  type             String // VIDEO, STATIC, CAROUSEL
  subtype          String? // AD, ORGANIC, STORY, REEL
  // Content
  title            String?
  scriptText       String?
  scriptFramework  String? // AIDA, PAS, PASTOR, etc.
  // Assets
  assetUrl         String? // Final creative URL (Drive)
  thumbnailUrl     String?
  // Metadata
  duration         Int? // For videos (seconds)
  dimensions       String? // "1080x1920", "1200x1200"
  format           String? // "mp4", "jpg", "png"
  // Avatar
  avatarId         String?
  avatar           Avatar?  @relation(fields: [avatarId], references: [id])
  // Funnel classification
  funnelStage      String? // COLD, WARM, HOT, RETARGETING
  targetAudience   String? // Avatar segment
  // Performance
  status           String   @default("DRAFT") // DRAFT, READY, TESTING, APPROVED, ARCHIVED
  performanceScore Float?
  // Drive organization
  driveFolderId    String?
  driveFileId      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([productId])
  @@index([funnelStage])
  @@index([status])
  @@index([type])
}

// Creative templates for static ads
model CreativeTemplate {
  id               String   @id @default(cuid())
  name             String
  category         String // VIDEO, STATIC, CAROUSEL
  funnelStage      String? // COLD, WARM, HOT
  // Template data
  templateJson     String // Layout, placeholders, fonts, colors
  previewUrl       String?
  // Constraints
  requiredFields   String? // JSON array
  supportedFormats String? // JSON array: ["1080x1920", "1200x1200"]
  usageCount       Int      @default(0)
  createdAt        DateTime @default(now())

  @@index([category])
  @@index([funnelStage])
}

// Script library with performance tracking
model ScriptLibrary {
  id             String   @id @default(cuid())
  productId      String?
  product        Product? @relation(fields: [productId], references: [id])
  framework      String // AIDA, PAS, PASTOR, BAB, etc.
  funnelStage    String // COLD, WARM, HOT, RETARGETING
  // Script content
  hook           String
  body           String
  cta            String
  // Metadata
  duration       Int? // Estimated seconds
  wordCount      Int?
  // Performance
  conversionRate Float?
  usageCount     Int      @default(0)
  avgCTR         Float?
  avgCPC         Float?
  createdAt      DateTime @default(now())

  @@index([productId])
  @@index([framework])
  @@index([funnelStage])
}

// ============================================
// CREATIVE SYSTEM MODELS
// ============================================

model GeneratedCreative {
  id        String  @id @default(cuid())
  productId String?
  storeId   String?

  type  String // 'VIDEO' | 'STATIC_AD' | 'LANDING_PAGE'
  stage String? // 'COLD' | 'WARM' | 'HOT'

  // Assets URLs
  avatarUrl    String?
  audioUrl     String?
  videoUrl     String
  thumbnailUrl String?
  captionsUrl  String? // Video con subtítulos

  // Metadata
  concept     String
  script      String?
  prompt      String?
  generatedBy String  @default("creative-factory")

  // Cost tracking
  generationCost Float @default(0)

  // Performance metrics (updated from ads)
  views       Int    @default(0)
  clicks      Int    @default(0)
  ctr         Float?
  conversions Int    @default(0)
  spend       Float  @default(0)
  revenue     Float  @default(0)

  // Quality & Learning
  qualityScore Float? // 1-10 by AI
  userRating   Int? // 1-5 by user
  status       String @default("GENERATED") // GENERATED | APPROVED | ARCHIVED

  // Relations
  product Product? @relation(fields: [productId], references: [id])
  store   Store?   @relation(fields: [storeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentPromptLibrary {
  id String @id @default(cuid())

  agentType String // 'video-editor' | 'design-cro' | 'caption-generator'
  category  String // 'hook' | 'transition' | 'cta' | 'layout' | 'color-grade'

  name        String
  prompt      String
  description String?

  // Learning metrics
  successRate     Float  @default(0.5)
  timesUsed       Int    @default(0)
  avgQualityScore Float?
  avgCTR          Float?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentLearning {
  id String @id @default(cuid())

  agentType  String
  taskType   String
  creativeId String? // Reference to GeneratedCreative

  // Input/Output
  inputData  String // JSON: request details
  outputData String // JSON: what was generated
  promptUsed String

  // Feedback
  userFeedback    String? // 'excellent' | 'good' | 'bad'
  qualityScore    Float?
  performanceData String? // JSON: CTR, conversions, etc

  createdAt DateTime @default(now())
}

// Nueva tabla para VOC Insights
model VOCInsight {
  id            String  @id @default(cuid())
  productId     String
  researchRunId String?

  phrase             String // La frase extraída
  category           String // 'PAIN' | 'DESIRE' | 'OBJECTION' | 'TRIGGER'
  emotionalIntensity Int // 1-10
  funnelStage        String? // 'COLD' | 'WARM' | 'HOT'
  frequency          Int     @default(1)
  verbatimSource     String? // Fuente original

  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([category])
}

// Nueva tabla para análisis competitivo
model CompetitiveAnalysis {
  id        String @id @default(cuid())
  productId String

  competitorName String
  competitorUrl  String?
  price          Float?
  rating         Float?
  reviewCount    Int?

  strengths      String // JSON array
  weaknesses     String // JSON array
  gapOpportunity String?

  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@index([productId])
}

// Nueva tabla para offer stacks
model OfferStack {
  id        String @id @default(cuid())
  productId String

  name       String // "1+1 Transformation Stack"
  strategy   String // '1+1' | 'BUNDLE' | 'UPGRADE'
  components String // JSON array de componentes

  totalValue Float
  price      Float
  discount   Float // Percentage

  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@index([productId])
}
// Nueva tabla para VOC Insights
model VOCInsight {
  id            String   @id @default(cuid())
  productId     String
  researchRunId String?
  
  phrase        String   // La frase extraída
  category      String   // 'PAIN' | 'DESIRE' | 'OBJECTION' | 'TRIGGER'
  emotionalIntensity Int  // 1-10
  funnelStage   String?  // 'COLD' | 'WARM' | 'HOT'
  frequency     Int      @default(1)
  verbatimSource String? // Fuente original
  
  product       Product  @relation(fields: [productId], references: [id])
  
  createdAt     DateTime @default(now())
  
  @@index([productId])
  @@index([category])
}

// Nueva tabla para análisis competitivo
model CompetitiveAnalysis {
  id            String   @id @default(cuid())
  productId     String
  
  competitorName String
  competitorUrl String?
  price         Float?
  rating        Float?
  reviewCount   Int?
  
  strengths     String   // JSON array
  weaknesses    String   // JSON array
  gapOpportunity String?
  
  product       Product  @relation(fields: [productId], references: [id])
  
  createdAt     DateTime @default(now())
  
  @@index([productId])
}

// Nueva tabla para offer stacks
model OfferStack {
  id            String   @id @default(cuid())
  productId     String
  
  name          String   // "1+1 Transformation Stack"
  strategy      String   // '1+1' | 'BUNDLE' | 'UPGRADE'
  components    String   // JSON array de componentes
  
  totalValue    Float
  price         Float
  discount      Float    // Percentage
  
  product       Product  @relation(fields: [productId], references: [id])
  
  createdAt     DateTime @default(now())
  
  @@index([productId])
}
// Research Snapshot Model for Auto-save & Version History
model ResearchSnapshot {
  id            String   @id @default(cuid())
  productId     String
  version       Int
  timestamp     DateTime @default(now())
  
  // Snapshot data (JSON)
  productDNA    String   // JSON: Product forensic analysis
  vocInsights   String   // JSON: VOC insights extracted
  avatars       String   // JSON: Avatar analysis
  angles        String   // JSON: Angle strategies
  
  // Meta
  completeness  Float    @default(0)  // 0-100%
  quality       Int      @default(0)  // 1-10
  
  product       Product  @relation(fields: [productId], references: [id])
  
  createdAt     DateTime @default(now())
  
  @@index([productId])
  @@index([version])
  @@unique([productId, version])
}

// Research Snapshot Model for Auto-save & Version History
model ResearchSnapshot {
  id            String   @id @default(cuid())
  productId     String
  version       Int
  timestamp     DateTime @default(now())
  
  // Snapshot data (JSON)
  productDNA    String   // JSON: Product forensic analysis
  vocInsights   String   // JSON: VOC insights extracted
  avatars       String   // JSON: Avatar analysis
  angles        String   // JSON: Angle strategies
  
  // Meta
  completeness  Float    @default(0)  // 0-100%
  quality       Int      @default(0)  // 1-10
  
  product       Product  @relation(fields: [productId], references: [id])
  
  createdAt     DateTime @default(now())
  
  @@index([productId])
  @@index([version])
  @@unique([productId, version])
}
